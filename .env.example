# Consolidated environment for local development and Compose
# WARNING: Do not commit real secrets. Keep this private.

# Postgres (Compose)
GRAVITY_POSTGRES_CONTAINER=gravity_postgres_dev
GRAVITY_POSTGRES_USER=gravity_user
GRAVITY_POSTGRES_PASSWORD=
POSTGRES_PASSWORD=
GRAVITY_POSTGRES_DB=gravity_workspace
GRAVITY_POSTGRES_PORT=5432

# Redis (Compose)
GRAVITY_REDIS_CONTAINER=gravity_redis_dev
GRAVITY_REDIS_PASSWORD=
GRAVITY_REDIS_PORT=6379

# Backend / app (Compose)
GRAVITY_BACKEND_CONTAINER=gravity_app_server
GRAVITY_BACKEND_PUBLIC_URL=http://localhost:8080
GRAVITY_BACKEND_PORT=8080

# Frontend (Compose)
GRAVITY_FRONTEND_CONTAINER=gravity_frontend
GRAVITY_FRONTEND_PORT=5173
GRAVITY_FRONTEND_PUBLIC_URL=https://gravity.themanagerworkspace.com

# Application runtime
PORT=8080
NODE_ENV=development

# Compose services are accessed via internal networks (postgres, redis)
# Do NOT use localhost here as the services do not expose ports to the host machine for security
DATABASE_URL=postgresql://gravity_user:<POSTGRES_PASSWORD>@postgres:5432/gravity_workspace

CORS_ORIGINS=http://localhost:5173,https://gravity.themanagerworkspace.com
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8080,https://gravity.themanagerworkspace.com

# Federation / timing
FEDERATION_SYNC_INTERVAL_MS=5000
FEDERATION_SYNC_FAILURE_BASE_MS=5000
FEDERATION_SYNC_FAILURE_MAX_MS=60000
FEDERATION_SYNC_FAILURE_MAX_RETRIES=5

# Redis for app
REDIS_URL=redis://default:<REDIS_PASSWORD>@redis:6379
REDIS_ENABLED=true

# Security keys
LOCAL_TESTING_KEK=
NODE_IDENTITY_MASTER_KEY=
BETTER_AUTH_SECRET=

# Misc

# RustFS object storage configuration
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=password
RUSTFS_BUCKET=notes

# GitHub webhook integration
# Set this to the secret configured on the GitHub webhook for HMAC-SHA256 signature verification.
# Generate a strong random value: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=
