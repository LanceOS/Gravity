PORT=8080
# Set a secure Postgres password or set DATABASE_URL directly
DATABASE_URL=postgresql://gravity_user:<POSTGRES_PASSWORD>@localhost:5432/gravity_workspace
BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8080
OLLAMA_DEFAULT_ENDPOINT=http://host.docker.internal:11434
FEDERATION_SYNC_INTERVAL_MS=5000
FEDERATION_SYNC_FAILURE_BASE_MS=5000
FEDERATION_SYNC_FAILURE_MAX_MS=60000
FEDERATION_SYNC_FAILURE_MAX_RETRIES=5

# SECURE CREDENTIAL STORAGE & KMS KEY ENCRYPTION KEY (KEK)
# Generate a secure 32-byte (256-bit) key: openssl rand -hex 32
LOCAL_TESTING_KEK=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# REDIS CACHING
# Set a secure Redis password or set REDIS_URL directly
REDIS_URL=redis://default:<REDIS_PASSWORD>@localhost:6379
REDIS_ENABLED=true