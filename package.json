{
  "name": "gravity",
  "version": "0.6.9",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm --workspace=client run build",
    "build:server": "npm --workspace=server run build",
    "start": "npm --workspace=server run start",
    "start:dev": "npm run -w server dev & npm run -w client dev",
    "sync-versions": "node ./scripts/sync-versions.js",
    "test": "npm run -w server test && npm run -w client test"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4"
  }
}
