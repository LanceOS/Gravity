# Example environment file for `docker/docker-compose.yml`
# Copy this to `.env` in the `docker/` folder (or set the variables in your environment).

# Postgres
GRAVITY_POSTGRES_CONTAINER=gravity_postgres
GRAVITY_POSTGRES_USER=gravity_user
GRAVITY_POSTGRES_PASSWORD=
GRAVITY_POSTGRES_DB=gravity_workspace
GRAVITY_POSTGRES_PORT=5432

# Redis
GRAVITY_REDIS_CONTAINER=gravity_redis
GRAVITY_REDIS_PASSWORD=
GRAVITY_REDIS_PORT=6379

# Backend / app
GRAVITY_BACKEND_CONTAINER=gravity_app_server
GRAVITY_BACKEND_PUBLIC_URL=http://localhost:8080
GRAVITY_BACKEND_PORT=8080
BETTER_AUTH_SECRET=
NODE_IDENTITY_MASTER_KEY=

# Frontend
GRAVITY_FRONTEND_CONTAINER=gravity_frontend
GRAVITY_FRONTEND_PORT=5173
GRAVITY_FRONTEND_PUBLIC_URL=http://localhost:5173

# Misc
DATABASE_URL=
REDIS_URL=
OLLAMA_DEFAULT_ENDPOINT=http://host.docker.internal:11434
NODE_ENV=production
REDIS_ENABLED=true
